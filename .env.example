# ---------------------------------------------------------------------------
# movie-trailer-mcp — environment configuration
#
# Copy to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- TMDB (primary source, same key as movie-metadata-mcp) -----------------

# TMDB v4 Read Access Token. Reuses exactly the same key you set for
# movie-metadata-mcp. Instructions to obtain:
#   1. https://www.themoviedb.org/ → Settings → API
#   2. Request a Developer key (free).
#   3. Copy the "API Read Access Token" (JWT-like string starting with "eyJ...").
TMDB_API_TOKEN=

# --- YouTube Data API v3 (optional fallback) -------------------------------

# When set, the server falls back to YouTube search when TMDB has no
# matching trailer. Quota: 10 000 units/day on the free tier; each
# search.list call costs 100 units.
# How to obtain:
#   1. https://console.cloud.google.com/ → create (or pick) a project.
#   2. APIs & Services → Library → enable "YouTube Data API v3".
#   3. APIs & Services → Credentials → "Create credentials" → API key.
#   4. Restrict the key to "YouTube Data API v3" for safety.
# Leave empty to disable the fallback entirely — TMDB remains the only source.
YOUTUBE_API_KEY=

# --- MCP transport ---------------------------------------------------------

# Bearer token required for HTTP+SSE / streamable-http transports.
# Must match the token configured in movie-handler-clients (.env).
MCP_AUTH_TOKEN=

# Transport: stdio | sse | streamable-http. Default: stdio.
# MCP_TRANSPORT=stdio

# Host / port for the HTTP transports. Defaults: 127.0.0.1:8766.
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8766

# --- Caching ---------------------------------------------------------------

# SQLite cache path (relative to the process working directory).
# CACHE_PATH=.cache/movie_trailer.sqlite
# CACHE_TTL_SECONDS=21600   # 6 hours
